base_url: https://etfapp.euler.southernfund.com:13000
shared_headers:
  Content-Type: application/json
  session: ""  # 从小程序抓包获取，过期后替换
task:
  name: 首趋E指
  interval_minutes: 5
schedule:
  start_hour: 6
  end_hour: 24
  daily_summary_hour: 6  # 每天几点发送前一天的日报（0-23）
notification:
  enabled: true
  feishu:
    webhook_url: ""     # 填飞书机器人 Webhook 地址
    # secret: ""        # 可选：签名校验密钥
  email:
    smtp_host: smtp.qq.com
    smtp_port: 465
    sender: ""          # 填你的QQ邮箱
    password: ""        # 填QQ邮箱授权码（非登录密码）
    receivers: []       # 填收件人邮箱列表
